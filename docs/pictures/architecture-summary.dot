    "src/modules/payment/application" -> "src/modules/payment/domain"
    subgraph "cluster_src" {label="src" subgraph "cluster_src/modules" {label="modules" subgraph "cluster_src/modules/payment" {label="payment" "src/modules/payment/domain" [label=<domain> tooltip="domain" URL="src/modules/payment/domain" shape="box3d"] } } }
    subgraph "cluster_src" {label="src" subgraph "cluster_src/modules" {label="modules" subgraph "cluster_src/modules/payment" {label="payment" "src/modules/payment/infrastructure" [label=<infrastructure> tooltip="infrastructure" URL="src/modules/payment/infrastructure" shape="box3d"] } } }
    "src/modules/payment/infrastructure" -> "src/modules/payment/application"
    "src/modules/payment/infrastructure" -> "src/modules/payment/domain"
    subgraph "cluster_src" {label="src" subgraph "cluster_src/modules" {label="modules" subgraph "cluster_src/modules/payment" {label="payment" "src/modules/payment/payment.module.ts" [label=<payment.module.ts> tooltip="payment.module.ts" URL="src/modules/payment/payment.module.ts" fillcolor="#eeeeee" style="filled" shape="folder"] } } }
