{
  "name": "code-payment-service",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "cross-env ENVIRONMENT=development nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "cross-env ENVIRONMENT=test jest",
    "test:watch": "cross-env ENVIRONMENT=test jest --watch",
    "test:cov": "cross-env ENVIRONMENT=test jest --coverage",
    "test:debug": "cross-env ENVIRONMENT=test node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "cross-env ENVIRONMENT=test jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm-ts-node-commonjs -d ./data-source.ts",
    "migration:generate": "npm run typeorm migration:generate",
    "migration:drop": "npm run typeorm schema:drop",
    "migration:revert": "npm run typeorm migration:revert",
    "migration:show": "npm run typeorm migration:show",
    "migration:run": "npm run typeorm migration:run",
    "ddd:check": "depcruise src",
    "ddd:docs": "bash scripts/depcruise-generate-docs.sh payment",
    "prepare": "husky"
  },
  "dependencies": {
    "@20206205tech/nestjs-auth": "^1.1.0",
    "@20206205tech/nestjs-common": "^0.11.2",
    "@getbrevo/brevo": "^5.0.4",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.23",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.3.0",
    "@nestjs/typeorm": "^11.0.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.218.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "axios": "^1.17.0",
    "bullmq": "^5.77.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "date-fns": "^4.1.0",
    "ioredis": "^5.11.0",
    "jwks-rsa": "^4.0.1",
    "kafkajs": "^2.2.4",
    "nestjs-vnpay": "^1.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^1.0.0",
    "vnpay": "^2.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.23",
    "@testcontainers/kafka": "^12.0.1",
    "@testcontainers/postgresql": "^11.14.0",
    "@testcontainers/redis": "^12.0.0",
    "@types/cron": "^2.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "dependency-cruiser": "^17.4.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "testcontainers": "^12.0.1",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.60.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "/node_modules/(?!(@20206205tech|jose|jwks-rsa)/)"
    ]
  },
  "overrides": {
    "protobufjs": "^8.1.0",
    "uuid": "^11.1.1"
  }
}
